# URL of the FastAPI backend.
# In local dev with `npm run dev`: leave unset — falls back to http://localhost:8000
# When using Cloudflare Tunnel: copy the https://xxxx.trycloudflare.com URL
# printed in the terminal after running backend/start.sh, then paste it here.
# On Vercel: add this as an environment variable in the project settings.
VITE_API_URL=https://your-tunnel-url.trycloudflare.com
